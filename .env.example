# =============================================================
# GLOBAL WEALTH RADAR — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================

# Supabase (Project Settings > API)
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Service Role (only for scripts, never in frontend)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Stripe (Dashboard > API Keys)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (Dashboard > Products)
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# Alpha Vantage (alphavantage.co — free)
ALPHA_VANTAGE_KEY=demo

# Financial Modeling Prep (optional — for fundamentals)
FMP_KEY=

# Resend (resend.com — free 3k emails/month)
RESEND_API_KEY=re_...

# Your domain
SITE_URL=https://globalwealthradar.com
