---
// src/pages/premium/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PremiumGuard from '../../components/PremiumGuard.astro';

const quickLinks = [
  { href: '/premium/etf-tracker',    icon: '📊', title: 'Full ETF Tracker',    desc: '200+ ETFs with history, fundamentals, and filters' },
  { href: '/premium/sovereign-risk', icon: '🗺️', title: 'Sovereign Risk Map',  desc: 'Country-by-country risk scores across 50 nations' },
  { href: '/premium/watchlist',      icon: '🔔', title: 'My Watchlist',         desc: 'Track your favorite ETFs with custom price alerts' },
];
---
<BaseLayout title="Premium Dashboard — Global Wealth Radar" description="Your premium investment dashboard" noindex={true}>
  <PremiumGuard>
    <DashboardLayout activeNav="/premium">

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        {[
          { label: 'Watchlist Items',   id: 'stat-wl',  icon: '🔔', val: '—'    },
          { label: 'ETFs Tracked',      id: 'stat-etf', icon: '📊', val: '200+' },
          { label: 'Countries Covered', id: 'stat-cnt', icon: '🌍', val: '50'   },
          { label: 'Active Alerts',     id: 'stat-alr', icon: '⚡', val: '—'    },
        ].map(s => (
          <div class="bg-surface-800 border border-slate-800 rounded-xl px-4 py-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-slate-500 text-xs">{s.label}</span>
              <span class="text-lg">{s.icon}</span>
            </div>
            <p id={s.id} class="text-white text-2xl font-bold font-mono">{s.val}</p>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-surface-800 border border-slate-800 rounded-2xl p-5">
          <h2 class="text-white font-semibold mb-4 flex justify-between">
            Top Movers Today
            <span class="text-xs text-slate-500 font-normal">All ETFs</span>
          </h2>
          <div id="top-movers"><p class="text-slate-500 text-sm animate-pulse">Loading...</p></div>
        </div>
        <div class="bg-surface-800 border border-slate-800 rounded-2xl p-5">
          <h2 class="text-white font-semibold mb-4 flex justify-between">
            My Watchlist
            <a href={`${import.meta.env.BASE_URL}premium/watchlist`} class="text-xs text-brand-400 hover:text-brand-300">Manage →</a>
          </h2>
          <div id="quick-wl"><p class="text-slate-500 text-sm animate-pulse">Loading...</p></div>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {quickLinks.map(c => (
          <a href={c.href} class="group bg-surface-800 border border-slate-800 hover:border-brand-500/40 rounded-2xl p-5 transition-colors">
            <div class="text-3xl mb-3">{c.icon}</div>
            <h3 class="text-white font-semibold mb-1 group-hover:text-brand-400 transition-colors">{c.title}</h3>
            <p class="text-slate-500 text-sm">{c.desc}</p>
          </a>
        ))}
      </div>

    </DashboardLayout>
  </PremiumGuard>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase.ts';

  function fmtPct(n: number | null) {
    if (n == null) return '<span class="text-slate-500">—</span>';
    const s = n >= 0 ? '+' : '';
    return `<span class="${n >= 0 ? 'text-brand-400' : 'text-red-400'} font-mono text-sm font-medium">${s}${n.toFixed(2)}%</span>`;
  }

  async function load() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const [{ data: movers }, { data: wl }, { data: alerts }] = await Promise.all([
      supabase.from('etf_data').select('ticker,nav,change_percent').order('change_percent', { ascending: false }).limit(5),
      supabase.from('watchlist').select('ticker').eq('user_id', user.id),
      supabase.from('watchlist_alerts').select('id').eq('user_id', user.id).eq('is_active', true),
    ]);

    document.getElementById('stat-wl')!.textContent  = String(wl?.length || 0);
    document.getElementById('stat-alr')!.textContent = String(alerts?.length || 0);

    const moversEl = document.getElementById('top-movers');
    if (moversEl && movers) {
      moversEl.innerHTML = movers.map(e => `
        <div class="flex justify-between py-2 border-b border-slate-800/60 last:border-0 items-center">
          <div>
            <span class="text-white font-mono font-bold text-sm">${e.ticker}</span>
            <span class="text-slate-500 text-xs ml-2">$${e.nav?.toFixed(2) || '—'}</span>
          </div>
          ${fmtPct(e.change_percent)}
        </div>`).join('');
    }

    if (wl?.length) {
      const tickers = wl.map(w => w.ticker);
      const { data: etfData } = await supabase.from('etf_data').select('ticker,nav,change_percent').in('ticker', tickers);
      const wlEl = document.getElementById('quick-wl');
      if (wlEl && etfData) {
        wlEl.innerHTML = etfData.map(e => `
          <div class="flex justify-between py-2 border-b border-slate-800/60 last:border-0 items-center">
            <span class="text-white font-mono font-bold text-sm">${e.ticker}</span>
            <div class="flex items-center gap-3">
              <span class="text-slate-400 text-sm">$${e.nav?.toFixed(2) || '—'}</span>
              ${fmtPct(e.change_percent)}
            </div>
          </div>`).join('');
      }
    } else {
      document.getElementById('quick-wl')!.innerHTML = `
        <p class="text-slate-500 text-sm">No tickers yet.</p>
        <a href="${import.meta.env.BASE_URL}premium/watchlist" class="text-brand-400 text-sm mt-2 inline-block">Add your first ETF →</a>`;
    }
  }
  load();
</script>
