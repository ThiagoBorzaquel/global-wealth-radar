---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PremiumGuard from '../../components/PremiumGuard.astro';
import ExportButton from '../../components/ExportButton.astro';

const categories = ['All', 'US Equity', 'International Equity', 'Bond', 'Commodity', 'Real Estate'];
---
<BaseLayout title="ETF Tracker — Global Wealth Radar" description="Full ETF tracker with 200+ ETFs" noindex={true}>
  <PremiumGuard>
    <DashboardLayout activeNav="/premium/etf-tracker">

      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">
        <div>
          <h1 class="text-xl font-bold text-white">ETF Tracker</h1>
          <p class="text-slate-500 text-sm" id="etf-count">Loading...</p>
        </div>
        <div class="flex items-center gap-3">
          <input id="search-input" type="text" placeholder="Search ticker or name..."
            class="bg-surface-800 border border-slate-700 text-white placeholder-slate-500 px-3 py-2 rounded-xl text-sm focus:outline-none focus:border-brand-500 w-48" />
          <ExportButton type="etf" label="Export CSV" />
        </div>
      </div>

      <div class="flex gap-1 mb-4 bg-surface-800 border border-slate-800 rounded-xl p-1 overflow-x-auto w-fit max-w-full">
        {categories.map((cat, i) => (
          <button class:list={['etf-tab px-3 py-1.5 rounded-lg text-sm transition-colors whitespace-nowrap',
            i === 0 ? 'bg-surface-700 text-white' : 'text-slate-400 hover:text-white']}
            data-tab={cat}>{cat}</button>
        ))}
      </div>

      <div class="bg-surface-800 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="grid px-4 py-3 border-b border-slate-800 text-xs text-slate-500 uppercase tracking-wider"
             style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr;">
          <span>ETF</span>
          <span class="text-right">Price</span>
          <span class="text-right">Today</span>
          <span class="text-right">YTD</span>
          <span class="text-right">Exp. Ratio</span>
        </div>
        <div id="etf-rows">
          {Array(8).fill(0).map(() => (
            <div class="grid px-4 py-4 border-b border-slate-800/60 animate-pulse"
                 style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr;">
              <div><div class="h-4 bg-slate-700 rounded w-12 mb-1"></div><div class="h-3 bg-slate-800 rounded w-40"></div></div>
              <div class="h-4 bg-slate-700 rounded w-16 ml-auto self-center"></div>
              <div class="h-4 bg-slate-700 rounded w-12 ml-auto self-center"></div>
              <div class="h-4 bg-slate-700 rounded w-12 ml-auto self-center"></div>
              <div class="h-4 bg-slate-700 rounded w-10 ml-auto self-center"></div>
            </div>
          ))}
        </div>
      </div>

    </DashboardLayout>
  </PremiumGuard>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase.ts';
  let all: any[] = [];
  let activeTab = 'All';
  let searchTerm = '';

  function fmtPct(n: number | null) {
    if (n == null) return '<span class="text-slate-500">—</span>';
    const s = n >= 0 ? '+' : '';
    return `<span class="${n >= 0 ? 'text-brand-400' : 'text-red-400'}">${s}${n.toFixed(2)}%</span>`;
  }

  function render(etfs: any[]) {
    const el = document.getElementById('etf-rows')!;
    if (!etfs.length) { el.innerHTML = '<p class="text-slate-500 text-sm p-6">No ETFs found.</p>'; return; }
    el.innerHTML = etfs.map(e => `
      <div class="grid px-4 py-4 border-b border-slate-800/60 hover:bg-surface-700/30 transition-colors items-center"
           style="grid-template-columns: 2fr 1fr 1fr 1fr 1fr;">
        <div>
          <p class="text-white font-mono font-bold text-sm">${e.ticker}</p>
          <p class="text-slate-500 text-xs mt-0.5 truncate max-w-[200px]">${e.name}</p>
          <p class="text-slate-700 text-xs">${e.category}</p>
        </div>
        <div class="text-right text-white font-mono text-sm">${e.nav ? '$' + e.nav.toFixed(2) : '—'}</div>
        <div class="text-right text-sm">${fmtPct(e.change_percent)}</div>
        <div class="text-right text-sm">${fmtPct(e.ytd_return)}</div>
        <div class="text-right text-slate-400 text-sm">${e.expense_ratio ? (e.expense_ratio * 100).toFixed(2) + '%' : '—'}</div>
      </div>`).join('');
  }

  function filter() {
    let filtered = activeTab === 'All' ? all : all.filter(e => e.category === activeTab);
    if (searchTerm) filtered = filtered.filter(e =>
      e.ticker.includes(searchTerm.toUpperCase()) || e.name.toLowerCase().includes(searchTerm.toLowerCase())
    );
    render(filtered);
  }

  async function load() {
    const { data } = await supabase
      .from('etf_data')
      .select('ticker,name,category,nav,change_percent,ytd_return,expense_ratio,last_updated')
      .order('ticker');
    all = data || [];
    document.getElementById('etf-count')!.textContent = `${all.length} ETFs · Updated daily`;
    filter();
  }

  document.querySelectorAll('.etf-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      activeTab = (tab as HTMLElement).dataset.tab!;
      document.querySelectorAll('.etf-tab').forEach(b => { b.classList.remove('bg-surface-700','text-white'); b.classList.add('text-slate-400'); });
      tab.classList.add('bg-surface-700','text-white'); tab.classList.remove('text-slate-400');
      filter();
    });
  });

  document.getElementById('search-input')?.addEventListener('input', (e) => {
    searchTerm = (e.target as HTMLInputElement).value;
    filter();
  });

  load();
</script>
