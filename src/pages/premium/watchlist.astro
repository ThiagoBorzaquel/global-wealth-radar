---
// src/pages/premium/watchlist.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import PremiumGuard from '../../components/PremiumGuard.astro';
import ExportButton from '../../components/ExportButton.astro';
---
<BaseLayout title="Watchlist — Global Wealth Radar" description="Your personal ETF watchlist with alerts" noindex={true}>
  <PremiumGuard>
    <DashboardLayout activeNav="/premium/watchlist">

      <div class="bg-surface-800 border border-slate-800 rounded-2xl p-5 mb-6">
        <h2 class="text-white font-semibold mb-4">Add ETF to Watchlist</h2>
        <div class="flex gap-3 flex-wrap items-center">
          <input id="ticker-input" type="text" placeholder="Ticker (e.g. VTI)" maxlength="10"
            class="bg-surface-700 border border-slate-700 text-white placeholder-slate-500 px-4 py-2.5 rounded-xl
                   text-sm focus:outline-none focus:border-brand-500 w-40 font-mono uppercase" />
          <button id="add-btn" class="bg-brand-500 hover:bg-brand-600 text-white font-medium px-5 py-2.5 rounded-xl text-sm transition-colors">Add</button>
          <ExportButton type="watchlist" label="Export" />
          <p id="add-error" class="text-red-400 text-sm hidden"></p>
        </div>
      </div>

      <div id="watchlist-list" class="space-y-3"></div>

      <!-- Alert modal -->
      <div id="alert-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-surface-800 border border-slate-700 rounded-2xl p-6 w-full max-w-sm">
          <h3 class="text-white font-bold text-lg mb-1">Set Alert</h3>
          <p id="modal-ticker" class="text-brand-400 font-mono font-bold mb-5 text-lg"></p>
          <div class="space-y-4">
            <div>
              <label class="text-slate-400 text-sm block mb-1.5">Alert Type</label>
              <select id="alert-type" class="w-full bg-surface-700 border border-slate-700 text-white px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:border-brand-500">
                <option value="price_above">Price rises above $</option>
                <option value="price_below">Price falls below $</option>
                <option value="change_above">Daily gain exceeds %</option>
                <option value="change_below">Daily drop exceeds %</option>
              </select>
            </div>
            <div>
              <label class="text-slate-400 text-sm block mb-1.5">Threshold</label>
              <div class="flex items-center gap-2">
                <span id="thresh-prefix" class="text-slate-400 font-mono">$</span>
                <input id="alert-threshold" type="number" step="0.01" min="0" placeholder="e.g. 250.00"
                  class="flex-1 bg-surface-700 border border-slate-700 text-white px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:border-brand-500" />
              </div>
            </div>
            <div>
              <label class="text-slate-400 text-sm block mb-1.5">Cooldown</label>
              <select id="alert-cooldown" class="w-full bg-surface-700 border border-slate-700 text-white px-3 py-2.5 rounded-xl text-sm focus:outline-none focus:border-brand-500">
                <option value="1">Once per hour</option>
                <option value="24" selected>Once per day</option>
                <option value="168">Once per week</option>
              </select>
            </div>
          </div>
          <div class="flex gap-3 mt-6">
            <button id="cancel-btn" class="flex-1 border border-slate-700 text-slate-400 py-2.5 rounded-xl text-sm hover:border-slate-500 transition-colors">Cancel</button>
            <button id="save-alert-btn" class="flex-1 bg-brand-500 hover:bg-brand-600 text-white font-medium py-2.5 rounded-xl text-sm transition-colors">Save Alert</button>
          </div>
        </div>
      </div>

    </DashboardLayout>
  </PremiumGuard>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase.ts';
  let userId = '';
  let alertTicker = '';

  function fmtPct(n: number | null) {
    if (n == null) return '<span class="text-slate-500">—</span>';
    const s = n >= 0 ? '+' : '';
    return `<span class="${n >= 0 ? 'text-brand-400' : 'text-red-400'} text-sm font-medium">${s}${n.toFixed(2)}%</span>`;
  }

  function alertLabel(a: any) {
    const sym: Record<string,string> = { price_above:'↑ >', price_below:'↓ <', change_above:'📈 >', change_below:'📉 <' };
    const val = a.alert_type.startsWith('change') ? `${a.threshold}%` : `$${a.threshold}`;
    return `${sym[a.alert_type] || ''} ${val}`;
  }

  async function loadWatchlist() {
    const [{ data: items }, { data: alerts }] = await Promise.all([
      supabase.from('watchlist').select('ticker,added_at').eq('user_id', userId).order('added_at', { ascending: false }),
      supabase.from('watchlist_alerts').select('*').eq('user_id', userId).eq('is_active', true),
    ]);

    const el = document.getElementById('watchlist-list')!;

    if (!items?.length) {
      el.innerHTML = `<div class="text-center py-16 text-slate-500">
        <p class="text-4xl mb-3">📋</p>
        <p class="text-slate-400 font-medium mb-1">Your watchlist is empty</p>
        <p class="text-sm">Add a ticker above to get started</p>
      </div>`;
      return;
    }

    const tickers = items.map(i => i.ticker);
    const { data: etfs } = await supabase.from('etf_data').select('ticker,name,nav,change_percent').in('ticker', tickers);
    const etfMap: Record<string,any> = {};
    etfs?.forEach(e => { etfMap[e.ticker] = e; });
    const alertMap: Record<string,any[]> = {};
    alerts?.forEach(a => { if (!alertMap[a.ticker]) alertMap[a.ticker] = []; alertMap[a.ticker].push(a); });

    el.innerHTML = items.map(item => {
      const e = etfMap[item.ticker];
      const itemAlerts = alertMap[item.ticker] || [];
      return `
        <div class="bg-surface-800 border border-slate-800 rounded-xl px-5 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div>
                <p class="text-white font-mono font-bold">${item.ticker}</p>
                <p class="text-slate-500 text-xs mt-0.5">${e?.name || '—'}</p>
              </div>
              ${itemAlerts.length ? `<span class="text-xs text-amber-400 bg-amber-400/10 border border-amber-400/20 px-2 py-0.5 rounded-full">${itemAlerts.length} alert${itemAlerts.length > 1 ? 's' : ''}</span>` : ''}
            </div>
            <div class="flex items-center gap-4">
              <div class="text-right">
                <p class="text-white font-mono text-sm">${e?.nav ? '$' + e.nav.toFixed(2) : '—'}</p>
                <div>${fmtPct(e?.change_percent)}</div>
              </div>
              <div class="flex gap-2">
                <button class="set-alert text-slate-400 hover:text-amber-400 p-1.5 rounded-lg hover:bg-amber-400/10 transition-colors" data-ticker="${item.ticker}" title="Set alert">🔔</button>
                <button class="remove-ticker text-slate-600 hover:text-red-400 p-1.5 rounded-lg hover:bg-red-400/10 transition-colors" data-ticker="${item.ticker}" title="Remove">✕</button>
              </div>
            </div>
          </div>
          ${itemAlerts.length ? `
            <div class="mt-3 pt-3 border-t border-slate-800/60 flex flex-wrap gap-2">
              ${itemAlerts.map(a => `
                <div class="flex items-center gap-2 text-xs bg-surface-700 rounded-lg px-3 py-1.5">
                  <span class="text-slate-400">${alertLabel(a)}</span>
                  <button class="del-alert text-slate-600 hover:text-red-400 transition-colors" data-id="${a.id}">✕</button>
                </div>`).join('')}
            </div>` : ''}
        </div>`;
    }).join('');

    // Event listeners
    el.querySelectorAll('.remove-ticker').forEach(btn => {
      btn.addEventListener('click', async () => {
        const t = (btn as HTMLElement).dataset.ticker!;
        await Promise.all([
          supabase.from('watchlist').delete().eq('user_id', userId).eq('ticker', t),
          supabase.from('watchlist_alerts').delete().eq('user_id', userId).eq('ticker', t),
        ]);
        loadWatchlist();
      });
    });
    el.querySelectorAll('.set-alert').forEach(btn => {
      btn.addEventListener('click', () => { alertTicker = (btn as HTMLElement).dataset.ticker!; openModal(); });
    });
    el.querySelectorAll('.del-alert').forEach(btn => {
      btn.addEventListener('click', async () => {
        await supabase.from('watchlist_alerts').delete().eq('id', (btn as HTMLElement).dataset.id!);
        loadWatchlist();
      });
    });
  }

  function openModal() {
    document.getElementById('modal-ticker')!.textContent = alertTicker;
    document.getElementById('alert-modal')!.classList.remove('hidden');
  }

  document.getElementById('add-btn')?.addEventListener('click', async () => {
    const inp = document.getElementById('ticker-input') as HTMLInputElement;
    const err = document.getElementById('add-error')!;
    const ticker = inp.value.trim().toUpperCase();
    if (!ticker) return;
    err.classList.add('hidden');
    const { error } = await supabase.from('watchlist').insert({ user_id: userId, ticker });
    if (error?.code === '23505') { err.textContent = 'Already in watchlist'; err.classList.remove('hidden'); }
    else if (error) { err.textContent = 'Error adding ticker'; err.classList.remove('hidden'); }
    else { inp.value = ''; loadWatchlist(); }
  });

  document.getElementById('ticker-input')?.addEventListener('keydown', e => { if (e.key === 'Enter') document.getElementById('add-btn')?.click(); });
  document.getElementById('cancel-btn')?.addEventListener('click', () => document.getElementById('alert-modal')!.classList.add('hidden'));

  document.getElementById('alert-type')?.addEventListener('change', e => {
    const t = (e.target as HTMLSelectElement).value;
    document.getElementById('thresh-prefix')!.textContent = t.startsWith('change') ? '%' : '$';
  });

  document.getElementById('save-alert-btn')?.addEventListener('click', async () => {
    const type     = (document.getElementById('alert-type') as HTMLSelectElement).value;
    const thresh   = parseFloat((document.getElementById('alert-threshold') as HTMLInputElement).value);
    const cooldown = parseInt((document.getElementById('alert-cooldown') as HTMLSelectElement).value);
    if (!thresh || isNaN(thresh)) { alert('Please enter a valid threshold'); return; }
    await supabase.from('watchlist_alerts').insert({ user_id: userId, ticker: alertTicker, alert_type: type, threshold: thresh, cooldown_hours: cooldown });
    document.getElementById('alert-modal')!.classList.add('hidden');
    loadWatchlist();
  });

  async function init() {
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;
    userId = user.id;
    loadWatchlist();
  }
  init();
</script>
