---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import NewsletterForm from '../../components/NewsletterForm.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => {
    // In Astro v6 with glob loader, use the 'id' field (filename without .md)
    const slug = post.id.replace('.md', '').split('/').pop() || post.id;
    return {
      params: { slug },
      props: { post }
    };
  });
}

const { post } = Astro.props;
// In Astro v6 with glob loader, the content is already in post.body as rendered HTML

const allPosts = await getCollection('blog');
const currentSlug = post.id.replace('.md', '').split('/').pop() || post.id;
const related  = allPosts
  .filter(p => {
    const pSlug = p.id.replace('.md', '').split('/').pop() || p.id;
    return pSlug !== currentSlug && p.data.category === post.data.category;
  })
  .slice(0, 3);

const siteUrl = 'https://globalwealthradar.com';
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout
  title={`${post.data.title} — Global Wealth Radar`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate || post.data.pubDate).toISOString(),
    author: { "@type": "Organization", name: post.data.author, url: siteUrl },
    publisher: { "@type": "Organization", name: "Global Wealth Radar", url: siteUrl },
  })} />

  <Header />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16">

    <nav class="text-sm text-slate-500 mb-8">
      <a href={`${import.meta.env.BASE_URL}`} class="hover:text-white">Home</a>
      <span class="mx-2">/</span>
      <a href={`${import.meta.env.BASE_URL}blog`} class="hover:text-white">Blog</a>
      <span class="mx-2">/</span>
      <span class="text-slate-400">{post.data.category}</span>
    </nav>

    <header class="mb-12">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-xs text-brand-400 font-medium bg-brand-500/10 border border-brand-500/20 px-3 py-1 rounded-full">
          {post.data.category}
        </span>
        {post.data.isPremium && (
          <span class="text-xs text-amber-400 bg-amber-500/10 border border-amber-500/20 px-3 py-1 rounded-full">🔒 Premium</span>
        )}
      </div>
      <h1 class="font-display text-4xl sm:text-5xl font-extrabold text-white leading-tight mb-6">{post.data.title}</h1>
      <p class="text-slate-400 text-xl leading-relaxed mb-6">{post.data.description}</p>
      <div class="flex items-center gap-4 text-sm text-slate-500 border-t border-slate-800 pt-6 flex-wrap">
        <div class="flex items-center gap-2">
          <div class="w-7 h-7 rounded-full bg-brand-500/20 flex items-center justify-center text-brand-400 text-xs font-bold">GW</div>
          <span>{post.data.author}</span>
        </div>
        <span>·</span>
        <time datetime={post.data.pubDate.toISOString()}>{fmtDate(post.data.pubDate)}</time>
        {post.data.updatedDate && <><span>·</span><span>Updated {fmtDate(post.data.updatedDate)}</span></>}
        {post.data.readingTime && <><span>·</span><span>{post.data.readingTime} min read</span></>}
      </div>
    </header>

    <!-- Paywall for premium posts -->
    {post.data.isPremium && (
      <div id="paywall-wrap">
        <div class="relative mt-8 rounded-2xl overflow-hidden" style="max-height:200px;">
          <div class="absolute inset-0 bg-gradient-to-b from-transparent via-surface-900/70 to-surface-900 z-10 flex items-end justify-center pb-10">
            <div class="text-center px-4">
              <p class="text-3xl mb-2">🔒</p>
              <h3 class="text-white font-bold text-xl mb-2">Premium Article</h3>
              <p class="text-slate-400 mb-4 max-w-sm text-sm">Available to Premium subscribers. Unlock for $19/month.</p>
              <div class="flex gap-3 justify-center">
                <a href={`${import.meta.env.BASE_URL}pricing`} class="bg-brand-500 hover:bg-brand-600 text-white font-semibold px-6 py-2.5 rounded-xl transition-colors">Unlock Premium →</a>
                <a href={`${import.meta.env.BASE_URL}auth/signin`} class="border border-slate-700 text-slate-300 px-6 py-2.5 rounded-xl hover:border-slate-500 transition-colors">Sign in</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    <div id="post-content"
      class:list={['prose prose-invert prose-lg max-w-none',
        'prose-headings:font-display prose-headings:font-bold',
        'prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4',
        'prose-p:text-slate-300 prose-p:leading-relaxed',
        'prose-a:text-brand-400 prose-a:no-underline hover:prose-a:underline',
        'prose-strong:text-white',
        'prose-code:text-brand-400 prose-code:bg-surface-800 prose-code:px-1 prose-code:py-0.5 prose-code:rounded',
        'prose-blockquote:border-brand-500 prose-blockquote:text-slate-400',
        'prose-table:text-sm prose-th:text-slate-300 prose-td:text-slate-400',
        { 'max-h-48 overflow-hidden': post.data.isPremium }
      ]}
      set:html={post.body}
    >
    </div>

    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-12 pt-8 border-t border-slate-800">
        {post.data.tags.map(tag => (
          <span class="text-xs text-slate-500 bg-surface-800 border border-slate-800 px-3 py-1 rounded-full">#{tag}</span>
        ))}
      </div>
    )}

    <div class="mt-16 bg-surface-800 border border-slate-800 rounded-2xl p-8 text-center">
      <h3 class="text-white font-bold text-xl mb-2">Get weekly macro intelligence</h3>
      <p class="text-slate-400 mb-6 text-sm">Join 5,000+ investors getting free ETF and global macro analysis.</p>
      <NewsletterForm source="blog" />
    </div>

    {related.length > 0 && (
      <section class="mt-16">
        <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-widest mb-6">Related Articles</h3>
        <div class="grid gap-4">
          {related.map(rp => {
            const rpSlug = rp.id.replace('.md', '').split('/').pop() || rp.id;
            return (
            <a href={`${import.meta.env.BASE_URL}blog/${rpSlug}`}
               class="group flex items-center gap-4 bg-surface-800 border border-slate-800 hover:border-slate-700 rounded-xl p-4 transition-colors">
              <div class="flex-1">
                <p class="text-xs text-slate-500 mb-1">{rp.data.category}</p>
                <h4 class="text-white font-medium group-hover:text-brand-400 transition-colors">{rp.data.title}</h4>
              </div>
              <span class="text-slate-600 group-hover:text-brand-500 transition-colors">→</span>
            </a>
            );
          })}
        </div>
      </section>
    )}
  </article>

  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase.ts';
  const paywall = document.getElementById('paywall-wrap');
  if (paywall) {
    supabase.auth.getUser().then(async ({ data: { user } }) => {
      if (!user) return;
      const { data: profile } = await supabase.from('profiles').select('is_premium').eq('id', user.id).single();
      if (profile?.is_premium) {
        paywall.remove();
        document.getElementById('post-content')?.classList.remove('max-h-48', 'overflow-hidden');
      }
    });
  }
</script>
