---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const year = new Date().getFullYear();
---
<BaseLayout title="Privacy Policy — Global Wealth Radar" description="How Global Wealth Radar collects and uses your data.">
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-display text-3xl font-bold text-white mb-8">Privacy Policy</h1>
    <div class="space-y-8 text-slate-400 text-sm leading-relaxed">
      <p class="text-slate-500">Last updated: January {year}</p>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">1. Data We Collect</h2>
        <p>We collect the following information when you use Global Wealth Radar:</p>
        <ul class="list-disc list-inside mt-2 space-y-1">
          <li><strong class="text-slate-300">Account data</strong>: name, email, profile picture, and sign-in credentials (Google OAuth or email/password)</li>
          <li><strong class="text-slate-300">Usage data</strong>: watchlist items, alert settings, newsletter subscription</li>
          <li><strong class="text-slate-300">Payment data</strong>: processed exclusively by Stripe — we never store card details</li>
        </ul>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">2. How We Use Your Data</h2>
        <ul class="list-disc list-inside space-y-1">
          <li>To provide and improve the service</li>
          <li>To send watchlist alerts and newsletter emails (only if you opted in)</li>
          <li>To process payments via Stripe</li>
          <li>We never sell your data to third parties</li>
        </ul>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">3. Data Storage</h2>
        <p>Your data is stored on Supabase (PostgreSQL), hosted on AWS infrastructure in the United States. Authentication is handled by Supabase Auth with industry-standard encryption.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">4. Your Rights</h2>
        <p>You may request deletion of your account and all associated data at any time by emailing <a href="mailto:hello@globalwealthradar.com" class="text-brand-400 hover:underline">hello@globalwealthradar.com</a>.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">5. Cookies</h2>
        <p>We use only essential cookies for authentication (Supabase session tokens). We do not use advertising or tracking cookies.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">6. Contact</h2>
        <p>Questions? Email <a href="mailto:hello@globalwealthradar.com" class="text-brand-400 hover:underline">hello@globalwealthradar.com</a></p>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
