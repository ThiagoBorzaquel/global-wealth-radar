---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterForm from '../components/NewsletterForm.astro';

const features = [
  { icon: '🌍', title: 'Global ETF Tracker',      desc: 'Monitor VTI, VXUS, EEM, GLD, TLT and 200+ ETFs with real-time macro overlays.' },
  { icon: '⚠️', title: 'Sovereign Risk Monitor',  desc: 'Country-by-country risk scores based on fiscal deficit, inflation, and political stability.' },
  { icon: '💱', title: 'Currency Diversification', desc: 'USD, EUR, CHF, SGD exposure analysis. Know where your wealth really lives.' },
  { icon: '📊', title: 'Portfolio Radar',          desc: 'Visual heatmap of your global exposure. See concentration risk at a glance.' },
  { icon: '🔔', title: 'Smart Alerts',             desc: 'Get notified when ETF prices or your watchlist crosses your thresholds.' },
  { icon: '📰', title: 'Macro Intelligence Blog',  desc: 'Weekly deep dives on global diversification and wealth protection strategies.' },
];
---

<BaseLayout
  title="Global Wealth Radar — ETF & Global Diversification Intelligence"
  description="Track ETFs, monitor sovereign risk, and protect your wealth across borders. The radar for globally-minded investors."
>
  <Header />

  <!-- HERO -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-surface-900">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-20"></div>
    <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-500/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
      <div class="inline-flex items-center gap-2 bg-brand-500/10 border border-brand-500/30 rounded-full px-4 py-1.5 mb-8">
        <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
        <span class="text-brand-400 text-sm font-medium">Live ETF & Macro Data</span>
      </div>

      <h1 class="font-display text-5xl sm:text-7xl font-extrabold text-white mb-6 leading-none">
        Your Global<br />
        <span class="text-brand-400">Wealth Radar</span>
      </h1>

      <p class="text-xl text-slate-400 max-w-2xl mx-auto mb-10">
        Track ETFs across markets, monitor currency exposure, assess sovereign risk,
        and build a truly global portfolio — all in one place.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={`${import.meta.env.BASE_URL}auth/signin`} class="bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl text-lg transition-colors">
          Start Free →
        </a>
        <a href={`${import.meta.env.BASE_URL}pricing`} class="border border-slate-700 hover:border-slate-500 text-slate-300 font-semibold px-8 py-4 rounded-xl text-lg transition-colors">
          View Pricing
        </a>
      </div>

      <p class="mt-8 text-sm text-slate-500">
        Trusted by 1,000+ globally-minded investors · No credit card required
      </p>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="py-24 bg-surface-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-4xl font-bold text-center text-white mb-4">
        Everything you need to invest globally
      </h2>
      <p class="text-slate-400 text-center mb-16 max-w-xl mx-auto">
        Built for Americans, expatriates, and high-income professionals who think beyond borders.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {features.map(f => (
          <div class="bg-surface-700/50 border border-slate-800 rounded-2xl p-6 hover:border-brand-500/30 transition-colors">
            <div class="text-4xl mb-4">{f.icon}</div>
            <h3 class="text-white font-semibold text-lg mb-2">{f.title}</h3>
            <p class="text-slate-400 text-sm leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING PREVIEW -->
  <section class="py-24 bg-surface-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-4xl font-bold text-white mb-4">Simple pricing</h2>
      <p class="text-slate-400 mb-12">Start free. Upgrade when you're ready.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-surface-800 border border-slate-800 rounded-2xl p-8 text-left">
          <div class="text-slate-400 font-medium mb-2">Free Forever</div>
          <div class="text-4xl font-bold text-white mb-6">$0</div>
          <ul class="space-y-3 text-slate-400 text-sm mb-8">
            {['Global dashboard', 'Top 20 ETF tracker', 'Macro news feed', 'Newsletter access'].map(f => (
              <li class="flex items-center gap-2"><span class="text-brand-500">✓</span>{f}</li>
            ))}
          </ul>
          <a href={`${import.meta.env.BASE_URL}auth/signin`} class="block text-center border border-slate-700 text-slate-300 font-medium py-3 rounded-xl hover:border-slate-500 transition-colors">
            Get Started Free
          </a>
        </div>

        <div class="bg-brand-500/10 border border-brand-500/40 rounded-2xl p-8 text-left relative">
          <div class="absolute top-4 right-4 bg-brand-500 text-white text-xs font-bold px-3 py-1 rounded-full">POPULAR</div>
          <div class="text-brand-400 font-medium mb-2">Premium</div>
          <div class="text-4xl font-bold text-white mb-6">$19<span class="text-lg text-slate-400 font-normal">/mo</span></div>
          <ul class="space-y-3 text-slate-300 text-sm mb-8">
            {['Everything in Free', '200+ ETF full tracker', 'Sovereign risk scores', 'Currency exposure analysis', 'Personal watchlist', 'Smart alerts', 'Premium blog posts'].map(f => (
              <li class="flex items-center gap-2"><span class="text-brand-500">✓</span>{f}</li>
            ))}
          </ul>
          <a href={`${import.meta.env.BASE_URL}pricing`} class="block text-center bg-brand-500 hover:bg-brand-600 text-white font-semibold py-3 rounded-xl transition-colors">
            Start Premium →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="py-24 bg-surface-800 border-t border-slate-800">
    <div class="max-w-xl mx-auto px-4 text-center">
      <h2 class="font-display text-3xl font-bold text-white mb-4">Global macro, weekly.</h2>
      <p class="text-slate-400 mb-8">
        Join 5,000+ investors getting our free weekly analysis on ETFs, currency risk, and global diversification.
      </p>
      <NewsletterForm source="landing" />
    </div>
  </section>

  <Footer />
</BaseLayout>
