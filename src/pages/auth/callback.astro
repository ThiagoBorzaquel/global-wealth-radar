---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Signing in..." description="" noindex={true}>
  <div class="min-h-screen bg-surface-900 flex items-center justify-center">
    <div class="text-center">
      <div class="w-10 h-10 border-2 border-brand-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
      <span class="text-brand-500 text-4xl block mb-3">◎</span>
      <p class="text-slate-400">Completing sign in...</p>
    </div>
  </div>
</BaseLayout>

<script>
  import { supabase } from '../../lib/supabase.ts';

  const baseUrl = import.meta.env.BASE_URL || '/';
  const normalizePath = (path: string | null) => {
    if (!path) return `${baseUrl}dashboard`;
    if (path.startsWith('http')) return `${baseUrl}dashboard`;
    if (path.startsWith(baseUrl)) return path;
    if (path.startsWith('/')) return baseUrl === '/' ? path : baseUrl + path.slice(1);
    return baseUrl + path;
  };

  const nextParam = new URLSearchParams(window.location.search).get('next');
  const next = normalizePath(nextParam);

  supabase.auth.onAuthStateChange((event, session) => {
    if (event === 'SIGNED_IN' && session) {
      window.location.href = next;
    }
  });

  // Fallback: if already signed in
  supabase.auth.getSession().then(({ data: { session } }) => {
    if (session) {
      window.location.href = next;
    }
  });
</script>
