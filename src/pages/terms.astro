---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const year = new Date().getFullYear();
---
<BaseLayout title="Terms of Use — Global Wealth Radar" description="Terms of use for Global Wealth Radar.">
  <Header />
  <main class="max-w-3xl mx-auto px-4 py-16">
    <h1 class="font-display text-3xl font-bold text-white mb-8">Terms of Use</h1>
    <div class="space-y-8 text-slate-400 text-sm leading-relaxed">
      <p class="text-slate-500">Last updated: January {year}</p>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">1. Acceptance</h2>
        <p>By using Global Wealth Radar, you agree to these terms. If you disagree, please do not use the service.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">2. Service Description</h2>
        <p>Global Wealth Radar provides financial data tools for informational purposes. We do not provide financial advice, and nothing on this platform should be construed as a recommendation to buy or sell any security.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">3. Subscriptions</h2>
        <p>Premium subscriptions are billed monthly or annually via Stripe. You may cancel at any time. Refunds are not provided for partial billing periods, but you retain access through the end of the paid period.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">4. Acceptable Use</h2>
        <p>You agree not to scrape, redistribute, or resell data from this platform. The service is for personal and internal business use only.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">5. Limitation of Liability</h2>
        <p>Global Wealth Radar is provided "as is." We are not liable for investment losses, data inaccuracies, or service interruptions. Use at your own risk.</p>
      </section>

      <section>
        <h2 class="text-white font-semibold text-lg mb-3">6. Contact</h2>
        <p>Questions? <a href="mailto:hello@globalwealthradar.com" class="text-brand-400 hover:underline">hello@globalwealthradar.com</a></p>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
