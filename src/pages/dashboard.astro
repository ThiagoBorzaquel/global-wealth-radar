---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);

const macroData = [
  { label: 'DXY (USD Index)', value: '104.32', change: '+0.21%', up: true  },
  { label: 'Gold (GLD)',      value: '$195.40', change: '+0.85%', up: true  },
  { label: 'Oil (WTI)',       value: '$78.20',  change: '-1.12%', up: false },
  { label: 'VIX (Volatility)',value: '14.8',    change: '-0.60',  up: false },
];

const tabs = ['All', 'US Equity', 'International', 'Bond', 'Commodity'];
---

<BaseLayout
  title="Global Markets Dashboard — Global Wealth Radar"
  description="Free global markets dashboard. Track top ETFs, monitor macro indicators, and stay ahead of global investment trends."
>
  <Header />

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-20">

    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Global Markets</h1>
        <p id="last-update" class="text-slate-500 text-sm mt-1">Loading market data...</p>
      </div>
      <div class="hidden sm:flex items-center gap-2 bg-surface-800 border border-slate-800 rounded-xl px-4 py-2">
        <span class="w-2 h-2 bg-brand-500 rounded-full animate-pulse"></span>
        <span class="text-slate-400 text-sm">Updated daily</span>
      </div>
    </div>

    <!-- Macro Indicators -->
    <section class="mb-8">
      <h2 class="text-xs text-slate-500 uppercase tracking-widest font-semibold mb-4">Macro Pulse</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {macroData.map(m => (
          <div class="bg-surface-800 border border-slate-800 rounded-xl p-4">
            <p class="text-slate-500 text-xs mb-2">{m.label}</p>
            <p class="text-white text-xl font-bold font-mono mb-1">{m.value}</p>
            <p class:list={[m.up ? 'text-brand-400' : 'text-red-400', 'text-xs font-medium']}>{m.change}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ETF Table -->
    <section class="mb-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs text-slate-500 uppercase tracking-widest font-semibold">Top ETFs</h2>
        <a href="/pricing" class="text-xs text-brand-400 hover:text-brand-300 transition-colors">See all 200+ in Premium →</a>
      </div>

      <div class="flex gap-1 mb-4 bg-surface-800 border border-slate-800 rounded-xl p-1 w-fit overflow-x-auto">
        {tabs.map((tab, i) => (
          <button
            class:list={['etf-tab px-3 py-1.5 rounded-lg text-sm transition-colors whitespace-nowrap',
              i === 0 ? 'bg-surface-700 text-white' : 'text-slate-400 hover:text-white']}
            data-tab={tab}
          >{tab}</button>
        ))}
      </div>

      <div class="bg-surface-800 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="grid px-4 py-3 border-b border-slate-800 text-xs text-slate-500 uppercase tracking-wider"
             style="grid-template-columns: 2fr 1fr 1fr 1fr;">
          <span>ETF</span>
          <span class="text-right">Price</span>
          <span class="text-right">Today</span>
          <span class="text-right">YTD</span>
        </div>
        <div id="etf-rows">
          {Array(6).fill(0).map(() => (
            <div class="grid px-4 py-4 border-b border-slate-800/60 animate-pulse"
                 style="grid-template-columns: 2fr 1fr 1fr 1fr;">
              <div><div class="h-4 bg-slate-700 rounded w-12 mb-1"></div><div class="h-3 bg-slate-800 rounded w-32"></div></div>
              <div class="h-4 bg-slate-700 rounded w-16 ml-auto"></div>
              <div class="h-4 bg-slate-700 rounded w-12 ml-auto"></div>
              <div class="h-4 bg-slate-700 rounded w-12 ml-auto"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bottom grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
      <!-- News feed -->
      <div class="lg:col-span-2">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-xs text-slate-500 uppercase tracking-widest font-semibold">Latest Research</h2>
          <a href="/blog" class="text-xs text-slate-500 hover:text-white transition-colors">All articles →</a>
        </div>
        <div class="space-y-3">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`}
               class="group flex gap-4 bg-surface-800 border border-slate-800 hover:border-slate-700 rounded-xl p-4 transition-colors">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 mb-1">
                  <span class="text-xs text-brand-400 font-medium">{post.data.category}</span>
                  {post.data.isPremium && <span class="text-xs text-amber-400">🔒</span>}
                </div>
                <h3 class="text-white text-sm font-medium group-hover:text-brand-400 transition-colors line-clamp-2">
                  {post.data.title}
                </h3>
                <p class="text-slate-500 text-xs mt-1">
                  {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  {post.data.readingTime && ` · ${post.data.readingTime} min`}
                </p>
              </div>
              <span class="text-slate-700 group-hover:text-brand-500 text-lg self-center transition-colors">→</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Sidebar -->
      <div>
        <h2 class="text-xs text-slate-500 uppercase tracking-widest font-semibold mb-4">Categories</h2>
        <div class="space-y-2 mb-4">
          {[
            { name: 'US Equity',     icon: '🇺🇸', tickers: ['VTI',  'SCHD'] },
            { name: 'International', icon: '🌍', tickers: ['VXUS', 'EEM']  },
            { name: 'Bonds',         icon: '📊', tickers: ['BND',  'TLT']  },
            { name: 'Commodities',   icon: '🥇', tickers: ['GLD',  'SLV']  },
          ].map(cat => (
            <div class="bg-surface-800 border border-slate-800 rounded-xl px-4 py-3">
              <div class="flex items-center justify-between mb-2">
                <span class="text-white text-sm font-medium">{cat.icon} {cat.name}</span>
                <span class="text-xs text-brand-400 cat-avg" data-tickers={cat.tickers.join(',')}>—</span>
              </div>
              <div class="flex gap-2">
                {cat.tickers.map(t => (
                  <span class="text-xs text-slate-500 bg-surface-700 px-2 py-0.5 rounded font-mono">{t}</span>
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="bg-brand-500/10 border border-brand-500/30 rounded-xl p-4">
          <p class="text-brand-400 text-sm font-semibold mb-1">🔒 Premium Access</p>
          <p class="text-slate-400 text-xs mb-3">200+ ETFs, sovereign risk scores, watchlist & alerts.</p>
          <a href="/pricing" class="block text-center bg-brand-500 hover:bg-brand-600 text-white text-sm font-medium py-2 rounded-lg transition-colors">
            Upgrade — $19/mo
          </a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { supabase } from '../lib/supabase.ts';

  let allETFs: any[] = [];

  function fmt(n: number | null, prefix = '') {
    if (n == null) return '—';
    return prefix + n.toFixed(2);
  }

  function fmtPct(n: number | null) {
    if (n == null) return '<span class="text-slate-500">—</span>';
    const sign = n >= 0 ? '+' : '';
    return `<span class="${n >= 0 ? 'text-brand-400' : 'text-red-400'}">${sign}${n.toFixed(2)}%</span>`;
  }

  function renderRows(etfs: any[]) {
    const el = document.getElementById('etf-rows');
    if (!el) return;
    if (!etfs.length) { el.innerHTML = '<p class="text-slate-500 text-sm p-6">No data yet.</p>'; return; }

    el.innerHTML = etfs.map(e => `
      <div class="grid px-4 py-4 border-b border-slate-800/60 hover:bg-surface-700/30 transition-colors"
           style="grid-template-columns: 2fr 1fr 1fr 1fr;" data-category="${e.category}">
        <div>
          <p class="text-white font-mono font-bold text-sm">${e.ticker}</p>
          <p class="text-slate-500 text-xs mt-0.5 truncate max-w-[180px]">${e.name}</p>
        </div>
        <div class="text-right text-white font-mono text-sm self-center">${e.nav ? '$' + e.nav.toFixed(2) : '—'}</div>
        <div class="text-right text-sm self-center">${fmtPct(e.change_percent)}</div>
        <div class="text-right text-sm self-center">${fmtPct(e.ytd_return)}</div>
      </div>
    `).join('');
  }

  async function load() {
    const { data } = await supabase
      .from('etf_data')
      .select('ticker,name,category,nav,change_percent,ytd_return,last_updated')
      .eq('is_premium', false)
      .order('ticker');

    allETFs = data || [];
    renderRows(allETFs);

    // Category averages
    document.querySelectorAll('.cat-avg').forEach(el => {
      const tickers = (el as HTMLElement).dataset.tickers?.split(',') || [];
      const relevant = allETFs.filter(e => tickers.includes(e.ticker));
      if (!relevant.length) return;
      const avg = relevant.reduce((s, e) => s + (e.change_percent || 0), 0) / relevant.length;
      el.className = `text-xs font-medium cat-avg ${avg >= 0 ? 'text-brand-400' : 'text-red-400'}`;
      el.textContent = `${avg >= 0 ? '+' : ''}${avg.toFixed(2)}%`;
    });

    if (allETFs[0]?.last_updated) {
      const d = new Date(allETFs[0].last_updated);
      const el = document.getElementById('last-update');
      if (el) el.textContent = `Last updated: ${d.toLocaleString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}`;
    }
  }

  // Tab filter
  document.querySelectorAll('.etf-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const t = (tab as HTMLElement).dataset.tab!;
      document.querySelectorAll('.etf-tab').forEach(b => {
        b.classList.remove('bg-surface-700','text-white'); b.classList.add('text-slate-400');
      });
      tab.classList.add('bg-surface-700','text-white'); tab.classList.remove('text-slate-400');

      const filtered = t === 'All' ? allETFs
        : t === 'International' ? allETFs.filter(e => e.category === 'International Equity')
        : allETFs.filter(e => e.category === t || (t === 'Bond' && e.category === 'Bond') || (t === 'Commodity' && e.category === 'Commodity'));
      renderRows(filtered);
    });
  });

  load();
</script>
