---
---
<header class="sticky top-0 z-50 bg-surface-900/80 backdrop-blur-xl border-b border-slate-800">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
    <a href={`${import.meta.env.BASE_URL}dashboard`} class="flex items-center gap-2">
      <span class="text-brand-500 text-2xl">◎</span>
      <span class="font-display font-bold text-white text-lg hidden sm:block">Global Wealth Radar</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      <a href={`${import.meta.env.BASE_URL}dashboard`} class="text-slate-400 hover:text-white text-sm transition-colors">Dashboard</a>
      <a href={`${import.meta.env.BASE_URL}blog`} class="text-slate-400 hover:text-white text-sm transition-colors">Blog</a>
      <a href={`${import.meta.env.BASE_URL}pricing`} class="text-slate-400 hover:text-white text-sm transition-colors">Pricing</a>
    </div>

    <div id="auth-buttons" class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-slate-800 animate-pulse"></div>
    </div>
  </nav>
</header>

<script>
  import { supabase } from '../lib/supabase.ts';

  async function renderAuth() {
    const container = document.getElementById('auth-buttons');
    if (!container) return;

    const { data: { user } } = await supabase.auth.getUser();
    container.innerHTML = '';

    if (user) {
      const { data: profile } = await supabase
        .from('profiles').select('avatar_url, is_premium').eq('id', user.id).single();

      container.innerHTML = `
        ${profile?.is_premium
          ? `<a href="${import.meta.env.BASE_URL}premium" class="text-brand-400 hover:text-brand-300 text-sm font-medium">★ Premium</a>`
          : `<a href="${import.meta.env.BASE_URL}pricing" class="text-xs bg-brand-500 hover:bg-brand-600 text-white font-medium px-3 py-1.5 rounded-lg transition-colors">Upgrade</a>`
        }
        <img src="${profile?.avatar_url || ''}" alt="avatar"
          class="w-8 h-8 rounded-full border border-slate-700 cursor-pointer" />
        <button id="signout-btn" class="text-slate-500 hover:text-slate-300 text-sm transition-colors">
          Sign out
        </button>
      `;
      document.getElementById('signout-btn')?.addEventListener('click', async () => {
        await supabase.auth.signOut();
        window.location.href = `${import.meta.env.BASE_URL}`;
      });
    } else {
      container.innerHTML = `
        <a href="${import.meta.env.BASE_URL}auth/signin" class="text-slate-300 hover:text-white text-sm transition-colors">Sign in</a>
        <a href="${import.meta.env.BASE_URL}pricing"
          class="bg-brand-500 hover:bg-brand-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
          Get Premium
        </a>
      `;
    }
  }
  renderAuth();
</script>
